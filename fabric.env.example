# Fabric endpoint configuration
# Set these after Fabric mirroring and RTI are configured.
# Usage: make update-fabric-endpoints \
#   FABRIC_SQL_ENDPOINT=<server> \
#   FABRIC_KQL_CLUSTER_URI=<uri> \
#   FABRIC_KQL_DATABASE=<db> \
#   FABRIC_KQL_TABLE=<table>

# Fabric SQL endpoint (from Database Settings → Connection strings)
FABRIC_SQL_ENDPOINT=
FABRIC_SQL_DATABASE=postgres-mirror

# Fabric KQL / Real-Time Intelligence (from KQL Database → Query URI)
FABRIC_KQL_CLUSTER_URI=
FABRIC_KQL_DATABASE=
FABRIC_KQL_TABLE=
