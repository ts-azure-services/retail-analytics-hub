# Fabric endpoint configuration
# Set these after Fabric mirroring and RTI are configured.
# Usage: make update-fabric-endpoints \
#   FABRIC_SQL_ENDPOINT=<server> \
#   FABRIC_KQL_CLUSTER_URI=<uri> \
#   FABRIC_KQL_DATABASE=<db> \
#   FABRIC_KQL_TABLE=<table>

# Fabric SQL endpoint (from Database Settings → Connection strings)
FABRIC_SQL_ENDPOINT=
FABRIC_SQL_DATABASE=postgres-mirror

# Fabric KQL / Real-Time Intelligence (from KQL Database → Query URI)
FABRIC_KQL_CLUSTER_URI=
FABRIC_KQL_DATABASE=
FABRIC_KQL_TABLE=

# EventHub — real-time review pipeline (cloud mode)
# EVENTHUB_RAW_NAME   = hub for inbound raw reviews (generator publishes here)
# EVENTHUB_PROCESSED_NAME = hub for outbound processed reviews (Agent 3 publishes here)
# The existing EventHub used by the sync/importer pipeline is separate.
EVENTHUB_NAMESPACE=
EVENTHUB_RAW_NAME=
EVENTHUB_PROCESSED_NAME=
EVENTHUB_CONSUMER_GROUP=$Default
