# Azure OpenAI credentials (using Azure AD — no API key needed)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Authentication uses DefaultAzureCredential (Azure CLI, Managed Identity, etc.)
# No API key required. See README for RBAC setup.

# DuckDB paths (set automatically via docker-compose volumes)
# LOCAL_POSTGRES_DB=/data/local_postgres.duckdb
# LOCAL_COSMOS_DB=/data/local_cosmos.duckdb

# Model overrides (optional — set per-service in docker-compose.yml)
# AGENT_MODEL=gpt-4o-mini
# AGENT_TEMPERATURE=0.3
